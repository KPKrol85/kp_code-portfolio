{
  "name": "everafterring",
  "version": "1.0.0",
  "description": "A static portfolio reference website for a premium wedding and ceremonial services brand.",
  "private": true,
  "author": "Kamil Król",
  "license": "UNLICENSED",
  "type": "module",
  "keywords": [
    "portfolio",
    "static-site",
    "wedding",
    "html",
    "css",
    "javascript"
  ],
  "scripts": {
    "clean": "node scripts/build.mjs clean",
    "optimize:images": "node scripts/optimize-images.mjs",
    "build:css": "node scripts/build.mjs css",
    "build:js": "node scripts/build.mjs js",
    "build:html": "node scripts/build.mjs html",
    "build:assets": "node scripts/build.mjs assets",
    "build": "npm run optimize:images && node scripts/build.mjs build"
  },
  "devDependencies": {
    "esbuild": "^0.28.0",
    "lightningcss": "^1.32.0",
    "sharp": "^0.34.5"
  }
}

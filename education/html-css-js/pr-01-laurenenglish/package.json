{
  "name": "lauren-english",
  "version": "1.0.0",
  "private": true,
  "license": "SEE LICENSE IN LICENSE.md",
  "type": "module",
  "scripts": {
    "dev": "python scripts/dev-server.py",
    "serve": "serve .",
    "check:data": "node scripts/check-content-data.mjs",
    "check:content": "node scripts/check-public-content.mjs",
    "check:css": "node scripts/check-css-quality.mjs && node scripts/check-css-contrast.mjs",
    "check:seo": "node scripts/check-seo.mjs",
    "check:pwa": "node scripts/check-pwa.mjs",
    "check:dev": "node scripts/check-dev-workflow.mjs",
    "test:e2e": "npm run build && playwright test",
    "test:e2e:smoke": "npm run build && playwright test tests/e2e/smoke.spec.mjs",
    "test:e2e:interactions": "npm run build && playwright test tests/e2e/interactions.spec.mjs",
    "test:e2e:theme": "npm run build && playwright test tests/e2e/theme.spec.mjs",
    "test:e2e:responsive": "npm run build && playwright test tests/e2e/responsive.spec.mjs",
    "test:e2e:seo": "npm run build && playwright test tests/e2e/seo-routing.spec.mjs",
    "test:e2e:pwa": "npm run build && playwright test tests/e2e/pwa.spec.mjs",
    "test:e2e:headed": "npm run build && playwright test --headed",
    "test:e2e:ui": "npm run build && playwright test --ui",
    "test:e2e:report": "playwright show-report playwright-report",
    "build:html": "node scripts/build-html.mjs",
    "check:html": "node scripts/build-html.mjs --check",
    "build:css": "node -e \"require('fs').mkdirSync('assets/build',{recursive:true})\" && postcss css/style.css -o assets/build/style.min.css",
    "watch:css": "node -e \"require('fs').mkdirSync('assets/build',{recursive:true})\" && postcss css/style.css -o assets/build/style.min.css --watch",
    "build:js": "node -e \"require('fs').mkdirSync('assets/build',{recursive:true})\" && esbuild js/main.js --bundle --minify --outfile=assets/build/main.min.js",
    "watch:js": "node -e \"require('fs').mkdirSync('assets/build',{recursive:true})\" && esbuild js/main.js --bundle --sourcemap=inline --watch --outfile=assets/build/main.min.js",
    "build:sw": "node scripts/build-service-worker.mjs",
    "build:pwa-screenshots": "node scripts/capture-pwa-screenshots.mjs",
    "build": "npm run build:html && npm run build:sw",
    "images": "node scripts/optimize-images.mjs",
    "lint:js": "eslint .",
    "format": "prettier --write \"**/*.{html,css,js,mjs,md,json,webmanifest,xml}\""
  },
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "@playwright/test": "^1.61.1",
    "concurrently": "^8.2.2",
    "cssnano": "^6.1.2",
    "esbuild": "^0.25.1",
    "eslint": "^9.18.0",
    "globals": "^15.15.0",
    "imagemin-avif": "^0.1.6",
    "imagemin-cli": "^8.0.0",
    "imagemin-webp": "^8.0.0",
    "postcss": "^8.4.38",
    "postcss-cli": "^11.0.0",
    "postcss-import": "^16.1.0",
    "prettier": "^3.2.5",
    "serve": "^14.2.3"
  }
}

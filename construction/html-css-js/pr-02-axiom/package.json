{
  "name": "axiom-construction",
  "version": "1.0.0",
  "private": true,
  "description": "Responsive construction company website (HTML/CSS/JS) with PWA, SEO, and accessibility \u2014 KP_Code.",
  "author": "KP_Code <kontakt@kp-code.pl>",
  "license": "MIT",
  "keywords": [
    "frontend",
    "construction",
    "pwa",
    "seo",
    "accessibility",
    "vanilla-js",
    "kp_code"
  ],
  "devDependencies": {
    "@lhci/cli": "^0.15.1",
    "cssnano": "^7.1.1",
    "cssnano-cli": "^1.0.5",
    "http-server": "^14.1.1",
    "lighthouse": "^12.2.1",
    "pa11y": "^8.0.0",
    "sharp": "^0.33.5",
    "terser": "^5.44.0",
    "ttf2woff2": "^8.0.0"
  },
  "scripts": {
    "img:build": "node tools/images/build-images.mjs",
    "img:clean": "node tools/images/build-images.mjs --clean",
    "build:clean": "node tools/release/clean-dist.mjs",
    "build:css": "node tools/css/build-css.mjs",
    "min:css": "npm run build:css",
    "build:js": "node tools/js/build-js.mjs",
    "build:sw": "node tools/sw/build-sw.mjs",
    "build:dist": "node tools/release/build-dist.mjs",
    "build": "npm run build:clean && npm run build:css && npm run build:js && npm run build:sw && npm run build:dist",
    "serve": "http-server -c-1 -p 8080",
    "serve:dist": "http-server dist -c-1 -p 8080",
    "qa:lighthouse": "node tools/qa/run-lighthouse.mjs",
    "qa:a11y": "node tools/qa/run-pa11y.mjs",
    "qa": "npm run qa:lighthouse && npm run qa:a11y",
    "build:head": "node tools/html/build-head.mjs"
  }
}

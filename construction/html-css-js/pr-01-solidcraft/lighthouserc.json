{
  "ci": {
    "collect": {
      "staticDistDir": "dist",
      "url": [
        "/",
        "/oferta/remonty.html",
        "/doc/polityka-prywatnosci.html"
      ],
      "numberOfRuns": 1
    },
    "assert": {
      "assertions": {
        "categories:performance": [
          "error",
          {
            "minScore": 0.6
          }
        ],
        "categories:accessibility": [
          "error",
          {
            "minScore": 0.85
          }
        ],
        "categories:seo": [
          "error",
          {
            "minScore": 0.85
          }
        ],
        "categories:best-practices": [
          "error",
          {
            "minScore": 0.75
          }
        ]
      }
    },
    "upload": {
      "target": "filesystem",
      "outputDir": ".lighthouseci"
    }
  }
}
